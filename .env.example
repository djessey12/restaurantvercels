# ─────────────────────────────────────────────────────────
# .env.local — Variables d'environnement
# ⚠️  NE JAMAIS COMMITTER CE FICHIER — il est dans .gitignore
# ─────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────
# Trouvez ces valeurs dans : Supabase Dashboard > Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...VOTRE_ANON_KEY

# ⚠️ SERVICE ROLE — Ne jamais exposer côté client !
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...VOTRE_SERVICE_ROLE_KEY

# ── Authentification JWT ──────────────────────────────────
# Généré par : node scripts/hash-passwords.mjs
# Minimum 32 caractères aléatoires

JWT_SECRET=REMPLACER_PAR_UNE_CHAINE_ALEATOIRE_FORTE_DE_48_CHARS

# ── Hashes des mots de passe (bcrypt, 12 rounds) ─────────
# Générés par : node scripts/hash-passwords.mjs

AUTH_HASH_CAISSIER=\$2a\$12\$...
AUTH_HASH_CUISINIER=\$2a\$12\$...
AUTH_HASH_CHEF=\$2a\$12\$...
AUTH_HASH_ADMIN=\$2a\$12\$...

# ── Application ───────────────────────────────────────────
# URL de production (utilisée pour la vérification CSRF)
# En développement, laisser vide ou mettre http://localhost:3000

NEXT_PUBLIC_APP_URL=https://VOTRE_DOMAINE.vercel.app
